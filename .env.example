# JAVA runtime options (optional)
JAVA_OPTS=

# Git repository settings
GIT_URI=
GIT_BRANCH=main
# Tìm kiếm theo mẫu common/service/profile
GIT_SEARCH_PATHS=common,{application},{profile}
GIT_REFRESH_RATE=30
GIT_SKIP_SSL=false
GIT_USERNAME=
GIT_TOKEN=

# Profile cho Config Server: git (mặc định) hoặc native
SPRING_PROFILES_ACTIVE=git
# Khi bật native, chỉ định nơi tìm cấu hình local (đã mount vào /app/configs)
NATIVE_SEARCH_LOCATIONS=file:///app/configs